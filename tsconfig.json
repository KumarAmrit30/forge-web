{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test-setup.ts", "tests/coach/**", "src/evaluation/runner/cli.ts", "src/evaluation/runner/brain-cli.ts", "src/evaluation/runner/personality-cli.ts", "src/evaluation/runner/hallucination-cli.ts", "src/evaluation/runner/execution-cli.ts", "src/evaluation/runner/regression-cli.ts", "src/evaluation/runner/release-cli.ts", "src/evaluation/runner/phase3-runner.ts", "src/evaluation/runner/phase3-report-writer.ts", "src/evaluation/brain/write-scenarios.ts", "src/evaluation/personality/**", "src/evaluation/hallucination/**", "src/evaluation/execution-eval/**", "src/evaluation/shared/**", "src/evaluation/regression/**", "src/evaluation/metrics/phase3-scores.ts", "src/evaluation/reports/phase3-html-report.ts", "src/evaluation/reports/release-html-dashboard.ts", "src/evaluation/reports/release-markdown-summary.ts"]
}
